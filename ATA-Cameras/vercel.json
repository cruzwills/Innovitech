{
    "version": 2,
    "framework": null,
    "buildCommand": "",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.8.0"
        }
    },
    "routes": [
        {
            "src": "/(.*\\.(?:css|js|jpg|jpeg|png|gif|svg|ico|woff|woff2|ttf|eot|map|webp|txt)$)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "VERCEL": "1",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "array",
        "LOG_CHANNEL": "stderr"
    }
}
